---
const timeline = [
  {
    period: '2025 — Now',
    role: 'Freelance',
    company: 'Charles Financial Strategies · Mothers to Daughters',
    location: 'New York, US',
    color: '#ff738e',
    highlights: [
      'Led the redesign websites',
      'Built SEO GEO strategy and content — 100% traffic growth',
      'Built the social media strategy — +1k followers within 3 months',
      'Led the monthly newsletter for 3k+ subscribers',
    ],
  },
  {
    period: '2022 — 2024',
    role: 'Digital Marketing Communications Project Manager',
    company: 'Ajinomoto Foods Europe',
    location: 'Paris, France',
    color: '#D4AF37',
    highlights: [
      'Led full website redesign (Drupal → WordPress) — +80% SEO traffic',
      'Built and launched client extranet platform for 2k+ clients',
      'Managed social media strategy: LinkedIn (3k) & Instagram (33k followers)',
      'Produced 50+ corporate videos with 40k+ cumulative views',
      'Managed corporate events across France',
    ],
  },
  {
    period: '2019 — 2022',
    role: 'Communications Manager',
    company: 'Imperial Tobacco Limited France',
    location: 'Paris, France',
    color: '#C0392B',
    highlights: [
      'Created and managed quarterly newsletter (print → digital)',
      'Distributed across 11 countries, 3,500 audience, +50% employee motivation',
      'Coordinated corporate events across the Africa cluster',
      'Built editorial charters and communications strategies',
    ],
  },
  {
    period: 'Earlier',
    role: 'Freelance',
    company: 'Deloitte · Selas Pharmacy · Dorgay Paris · GTO media · LMED',
    location: 'Paris, France',
    color: '#6B5EA8',
    highlights: [
      'Built diverse experience across consulting, retail, media and health sectors',
      'Developed expertise in photography, video production and brand identity',
      'Strengthened bilingual (EN/FR) communications skills across international teams',
    ],
  },
];
---

<section class="timeline-section" id="timeline">
  <div class="container">
    <p class="section-label scroll-reveal">Career</p>
    <h2 class="section-title scroll-reveal">7 Years of<br /><em>experience</em></h2>

    <div class="timeline">
      {timeline.map((item, i) => (
        <div class="timeline-item scroll-reveal" style={`transition-delay: ${i * 0.15}s`}>
          <div class="timeline-left">
            <span class="timeline-period">{item.period}</span>
            <div class="timeline-dot" style={`background: ${item.color}`}></div>
          </div>
          <div class="timeline-line" style={`border-color: ${item.color}40`}></div>
          <div class="timeline-right">
            <div class="timeline-card" style={`--accent: ${item.color}`}>
              <div class="tc-header">
                <h3 class="tc-role">{item.role}</h3>
                <div class="tc-meta">
                  <span class="tc-company">{item.company}</span>
                  <span class="tc-location">📍 {item.location}</span>
                </div>
              </div>
              <ul class="tc-highlights">
                {item.highlights.map(h => (
                  <li>{h}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.timeline-section {
  padding: var(--section-pad) 0;
  background: transparent;
  border-top: 1px solid rgba(0,0,0,0.06);
}

.timeline {
  margin-top: 4rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: grid;
  grid-template-columns: 160px 2px 1fr;
  gap: 0 2.5rem;
  align-items: stretch;
  min-height: 180px;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-start;
  padding-top: 1.5rem;
  gap: 0.75rem;
}

.timeline-period {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  color: var(--c-muted);
  text-align: right;
  line-height: 1.4;
}

.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  margin-right: -7px;
  flex-shrink: 0;
  box-shadow: 0 0 0 3px white, 0 0 0 5px currentColor;
  margin-top: 2px;
}

.timeline-line {
  width: 2px;
  border-left: 2px solid rgba(0,0,0,0.1);
  margin: 0;
  position: relative;
}

.timeline-item:last-child .timeline-line {
  border-style: dashed;
  opacity: 0.4;
}

.timeline-right {
  padding: 0 0 3rem 0;
}

.timeline-card {
  border: 1px solid rgba(0,0,0,0.08);
  background: white;
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.3s, transform 0.3s;
}
.timeline-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--accent, var(--c-orange));
}
.timeline-card:hover {
  box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  transform: translateX(4px);
}

.tc-header {
  padding: 1.5rem 1.75rem 1.25rem;
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.tc-role {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--c-dark);
  margin-bottom: 0.5rem;
  line-height: 1.2;
}

.tc-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
}

.tc-company {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent, var(--c-orange));
  font-weight: 500;
}

.tc-location {
  font-size: 0.78rem;
  color: var(--c-muted);
}

.tc-highlights {
  list-style: none;
  padding: 1.25rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.tc-highlights li {
  font-size: 0.88rem;
  line-height: 1.6;
  color: #4A3828;
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
}

.tc-highlights li::before {
  content: '→';
  color: var(--accent, var(--c-orange));
  flex-shrink: 0;
  font-size: 0.8rem;
  margin-top: 2px;
}

@media (max-width: 640px) {
  .timeline-item {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .timeline-left { flex-direction: row; align-items: center; }
  .timeline-line { display: none; }
  .timeline-dot { margin-right: 0; }
  .timeline-period { text-align: left; }
}
</style>
