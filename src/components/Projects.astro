---

<section class="projects" id="projects">
  <div class="container">
    <div class="projects-header scroll-reveal">
      <p class="section-label">Selected Work</p>
      <h2 class="section-title">My <em>Projects</em></h2>
      <p class="projects-sub">7 case studies across digital project management, content production, and communications strategy.</p>
    </div>

    <div class="projects-index scroll-reveal">
      {projects.map(p => (
        <a href={`#${p.id}`} class="index-item">
          <span class="index-num">{p.number}</span>
          <span class="index-name">{p.title}</span>
          <span class="index-company">{p.company}</span>
          <span class="index-arrow">→</span>
        </a>
      ))}
    </div>

    <div class="case-studies">
      {projects.map((project) => (
        <article class="case-study scroll-reveal" id={project.id}>
          <div class="cs-header" style={`--accent: ${project.color}`}>
            {project.coverImg && (
              <div class="cs-cover" style={`background-image: url('${project.coverImg}'); background-position: ${project.coverPosition ?? 'center'}; background-size: ${project.coverSize ?? 'cover'};`}></div>
            )}
            <div class="cs-header-overlay"></div>
            <div class="cs-header-inner">
              <div class="cs-meta">
                <span class="cs-num">{project.number}</span>
                <span class="cs-tag">{project.tag}</span>
              </div>
              <h3 class="cs-title">{project.title}</h3>
              <p class="cs-company">{project.company}</p>
              {project.tagline && <p class="cs-tagline">"{project.tagline}"</p>}
            </div>
          </div>

          <div class="cs-body">
            <div class="cs-context">
              <p class="section-label">Context</p>
              <p class="cs-context-text">{project.context}</p>
            </div>

            {project.steps.length > 0 && (
              <div class="cs-steps">
                <p class="section-label">How I managed this project</p>
                <div class="step-grid">
                  {project.steps.map(step => (
                    <div class="step-item">
                      <span class="step-num">{step.num}</span>
                      <h4>{step.title}</h4>
                      <p>{step.desc}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.phases.length > 0 && (
              <div class="cs-phases">
                {project.phases.map(phase => (
                  <div class="phase-block">
                    <h4>{phase.title}</h4>
                    <p>{phase.text}</p>
                  </div>
                ))}
              </div>
            )}

            {project.galleryImgs.length > 0 && (
              <div class="cs-gallery">
                <p class="section-label">Gallery</p>
                <div class={`gallery-grid cols-${Math.min(project.galleryImgs.length, 3)}`}>
                  {project.galleryImgs.map((img, i) => (
                    <div class="gallery-item">
                      {project.galleryLinks?.[i] ? (
                        <a href={project.galleryLinks[i]} target="_blank" rel="noopener">
                          <img src={img} alt={`${project.title} — ${i + 1}`} loading="lazy" />
                        </a>
                      ) : (
                        <img src={img} alt={`${project.title} — ${i + 1}`} loading="lazy" />
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.videos.length > 0 && (
              <div class="cs-videos">
                <p class="section-label">Videos</p>
                <p class="video-note">
                  Replace <code>PLACEHOLDER_X</code> in <code>Projects.astro</code> with real YouTube video IDs to activate embeds.
                </p>
                <div class="video-grid">
                  {project.videos.map((v) => (
                    <div class="video-item">
                      <div class="video-embed-wrapper">
                        {v.id.startsWith('PLACEHOLDER') ? (
                          <div class="video-placeholder">
                            <span class="vp-icon">▶</span>
                            <span class="vp-label">{v.title}</span>
                            <span class="vp-hint">Add YouTube ID in Projects.astro</span>
                          </div>
                        ) : (
                          <iframe
                            src={`https://www.youtube.com/embed/${v.id}`}
                            title={v.title}
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen
                          ></iframe>
                        )}
                      </div>
                      <p class="video-title">{v.title}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.stats.length > 0 && (
              <div class="stats-row">
                {project.stats.map(stat => (
                  <div class="stat-chip">
                    <span class="value">{stat.value}</span>
                    <span class="label">{stat.label}</span>
                  </div>
                ))}
              </div>
            )}

            {project.link && (
              <div class="cs-link">
                <a href={project.link.url} class="cta-link" target="_blank" rel="noopener">
                  {project.link.label} →
                </a>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.projects { padding: var(--section-pad) 0; background: var(--c-warm-white); }
.projects-header { margin-bottom: 4rem; }
.projects-sub { font-size: 1rem; color: var(--c-muted); margin-top: 1.25rem; max-width: 50ch; }

.projects-index { display: flex; flex-direction: column; border: 1px solid rgba(0,0,0,0.08); margin-bottom: 6rem; }
.index-item {
  display: grid; grid-template-columns: 3rem 1fr 1fr 2rem; align-items: center; gap: 1rem;
  padding: 1.1rem 1.5rem; text-decoration: none; color: var(--c-dark);
  border-bottom: 1px solid rgba(0,0,0,0.06); transition: background 0.2s, padding-left 0.2s;
}
.index-item:last-child { border-bottom: none; }
.index-item:hover { background: var(--c-cream); padding-left: 2rem; }
.index-num { font-family: var(--font-mono); font-size: 0.65rem; color: var(--c-orange); letter-spacing: 0.1em; }
.index-name { font-family: var(--font-display); font-weight: 700; font-size: 1rem; }
.index-company { font-size: 0.82rem; color: var(--c-muted); }
.index-arrow { color: var(--c-orange); transition: transform 0.2s; }
.index-item:hover .index-arrow { transform: translateX(4px); }

.case-studies { display: flex; flex-direction: column; gap: 6rem; }
.case-study { border: 1px solid rgba(0,0,0,0.08); overflow: hidden; }

.cs-header { position: relative; min-height: 300px; display: flex; align-items: flex-end; overflow: hidden; }
.cs-cover {
  position: absolute; inset: 0;
  transition: transform 0.6s ease;
}
.case-study:hover .cs-cover { transform: scale(1.03); }
.cs-header-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(26,16,7,0.48) 30%, rgba(26,16,7,0.25) 70%, rgba(26,16,7,0.08) 100%);
}
.cs-header-inner { position: relative; z-index: 1; padding: 2.5rem; width: 100%; }
.cs-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
.cs-num { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.15em; color: rgba(255,255,255,0.4); }
.cs-tag { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: white; background: var(--accent, var(--c-orange)); padding: 0.25rem 0.75rem; }
.cs-title { font-family: var(--font-display); font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 900; color: white; line-height: 1; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
.cs-company { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; color: rgba(255,255,255,0.5); text-transform: uppercase; margin-bottom: 0.75rem; }
.cs-tagline { font-family: var(--font-display); font-style: italic; font-size: 1rem; color: rgba(255,255,255,0.6); }

.cs-body { padding: 3rem; background: white; }
.cs-context { margin-bottom: 3rem; }
.cs-context-text { font-size: 0.95rem; line-height: 1.85; color: #4A3828; max-width: 72ch; margin-top: 1rem; padding: 1.5rem 2rem; background: var(--c-cream); border-left: 3px solid var(--c-orange); }
.cs-steps { margin-bottom: 3rem; }
.cs-phases { margin-bottom: 2rem; }
.cs-link { margin-top: 2rem; }

.cs-gallery { margin: 2rem 0 3rem; }
.gallery-grid { display: grid; gap: 0.5rem; margin-top: 1rem; }
.cols-1 { grid-template-columns: 1fr; }
.cols-2 { grid-template-columns: 1fr 1fr; }
.cols-3 { grid-template-columns: repeat(3, 1fr); }
.gallery-item { overflow: hidden; aspect-ratio: 16/10; background: var(--c-cream); }
.gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.gallery-item:hover img { transform: scale(1.06); }

/* Videos */
.cs-videos { margin: 2rem 0 3rem; }
.video-note { font-size: 0.8rem; color: var(--c-muted); margin: 0.75rem 0 1.5rem; padding: 0.75rem 1rem; background: rgba(212,175,55,0.06); border-left: 2px solid var(--c-orange); font-style: italic; }
.video-note code { font-family: var(--font-mono); font-size: 0.72rem; background: rgba(0,0,0,0.06); padding: 0.1rem 0.3rem; }
.video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
.video-embed-wrapper { aspect-ratio: 16/9; overflow: hidden; background: var(--c-dark); }
.video-embed-wrapper iframe { width: 100%; height: 100%; border: none; }
.video-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; background: var(--c-dark); }
.vp-icon { font-size: 2rem; color: rgba(255,255,255,0.2); }
.vp-label { font-family: var(--font-display); font-size: 0.85rem; font-weight: 600; color: rgba(255,255,255,0.6); text-align: center; padding: 0 1rem; }
.vp-hint { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.08em; color: var(--c-orange); text-transform: uppercase; text-align: center; }
.video-title { font-size: 0.82rem; color: var(--c-muted); margin-top: 0.5rem; font-style: italic; }

@media (max-width: 640px) {
  .index-item { grid-template-columns: 2rem 1fr 1.5rem; }
  .index-company { display: none; }
  .cols-3 { grid-template-columns: 1fr 1fr; }
  .cs-body { padding: 2rem 1.5rem; }
}
</style>
