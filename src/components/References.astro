---
const references = [
  {
    quote: "Lan is a very organized person who can lead projects easily: gathering input data, sharing with and convincing the members, making the steps and following the realization. Reporting KPI transparently is very appreciated. The management of subcontractors is also good, whether digital support designers or media artists. She also has extensive knowledge about digital communications, like the good practices, the process to build websites, the metrics, and the structuration of animation. She can produce attractive visuals with no external help when necessary.",
    name: "Yves Dusquenoy",
    title: "General Manager",
    company: "Ajinomoto Foods Europe",
  },
  {
    quote: "Lan is a valuable ally in our communications team at Imperial Tobacco Limited France. Together, we were able to implement new initiatives, such as newsletter, intranet, and website. She supported me on all the events that punctuate the year, including some abroad. Lan is focused on innovation and never short of ideas. Her refreshing, creative vision and technical expertise (Social Media, Adobe Suite, Microsoft 365, Figma, Filmora) contribute to maintaining an agile and human communications strategy.",
    name: "Florence Lequin",
    title: "Executive Assistant",
    company: "Imperial Tobacco Limited France",
  },
  {
    quote: "I highly recommend Lan for any team or organization. I have truly enjoyed working with her as our Digital Marketing and Social Media Specialist at Mothers to Daughters. She brings clarity, intention, and strategic depth to our communications. Lan leads our monthly newsletter with strong editorial judgment, consistently translating our mission and initiatives into compelling and accessible storytelling that resonates with our community. Her social media strategy reflects a sophisticated understanding of audience, brand positioning, and measurable impact. Through her leadership, our visibility and engagement have strengthened in meaningful and sustainable ways. Lan is dependable, thoughtful, and a trusted strategic partner. I recommend her without hesitation.",
    name: "Francine Mbovumbo, MBA",
    title: "Strategic Partnerships Advisor",
    company: "Mothers to Daughters",
  },
];
---

<section class="references" id="references">
  <div class="references-bg">
    <div class="ref-pattern"></div>
  </div>
  <div class="container">
    <p class="section-label scroll-reveal" style="color: rgba(255,255,255,0.5)">References</p>
    <h2 class="section-title scroll-reveal" style="color: white">What people<br /><em>say about me</em></h2>

    <div class="ref-grid">
      {references.map((ref, i) => (
        <blockquote class={`ref-card scroll-reveal`} style={`transition-delay: ${i * 0.15}s`}>
          <div class="ref-quote-mark">"</div>
          <p class="ref-text">{ref.quote}</p>
          <footer class="ref-footer">
            <div class="ref-info">
              <strong class="ref-name">{ref.name}</strong>
              <span class="ref-role">{ref.title} · {ref.company}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
.references {
  padding: var(--section-pad) 0;
  background: var(--c-dark);
  position: relative;
  overflow: hidden;
}
.references-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.ref-pattern {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 20% 80%, rgba(212,175,55,0.08) 0%, transparent 50%),
                    radial-gradient(circle at 80% 20%, rgba(244,167,163,0.06) 0%, transparent 50%);
}
.container { position: relative; z-index: 1; }
.section-title em { color: var(--c-pink); }

.ref-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
  gap: 2rem;
  margin-top: 4rem;
}
.ref-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 2.5rem;
  position: relative;
  transition: border-color 0.3s, background 0.3s;
}
.ref-card:hover {
  border-color: rgba(212,175,55,0.4);
  background: rgba(255,255,255,0.06);
}
.ref-quote-mark {
  font-family: var(--font-display);
  font-size: 5rem;
  line-height: 1;
  color: var(--c-orange);
  opacity: 0.4;
  position: absolute;
  top: 1rem;
  left: 2rem;
}
.ref-text {
  font-size: 0.92rem;
  line-height: 1.85;
  color: rgba(255,255,255,0.65);
  margin-top: 2rem;
  font-style: italic;
}
.ref-footer {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.ref-name {
  display: block;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: white;
}
.ref-role {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  color: var(--c-orange);
  text-transform: uppercase;
  margin-top: 0.25rem;
  display: block;
}

@media (max-width: 600px) {
  .ref-grid { grid-template-columns: 1fr; }
}
</style>
